<section id="contactSection" class="bg-white py-16 md:py-32 px-6 md:px-0">
  <div
    class="container mx-auto p-8 md:p-16 grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-0 bg-[#2B3437] text-white rounded-3xl md:rounded-[48px]"
  >
    {{! Text }}
    <div
      class="flex flex-col gap-6 md:gap-8 justify-center text-center lg:text-left"
    >
      <h2
        class="font-extrabold text-4xl md:text-6xl tracking-[-3px] leading-tight md:leading-16"
      >
        Ready to Scale?
        <br class="hidden md:block" />
        Let's Connect.
      </h2>
      <p class="text-base md:text-lg text-[#CED4E9]">
        Have a vision for a project? Let's build something that stands the test
        of time.
      </p>
      {{! Email & Location }}
      <div class="flex flex-col gap-6 items-center lg:items-start mt-4">
        <div class="flex gap-4 items-center">
          <i class="fa-solid fa-envelope"></i>
          <p class="text-lg md:text-xl font-bold">
            helmy@gmail.com
          </p>
        </div>
        <div class="flex gap-4 items-center">
          <i class="fa-solid fa-location-dot"></i>
          <p class="text-lg md:text-xl font-bold">
            Bekasi, Indonesia
          </p>
        </div>
      </div>
    </div>
    {{! Form }}
    <div class="flex flex-col gap-6">
      <input
        type="text"
        placeholder="Full Name"
        class="bg-[#4B5264]/20 py-[18px] px-6 rounded-full outline-none"
      />
      <input
        type="text"
        placeholder="Email Address"
        class="bg-[#4B5264]/20 py-[18px] px-6 rounded-full outline-none"
      />
      <textarea
        name=""
        id=""
        placeholder="Your Message"
        rows="6"
        class="bg-[#4B5264]/20 py-[18px] px-6 rounded-3xl outline-none"
        style="resize: none;"
      ></textarea>
      <button
        type="submit"
        class="bg-white text-[#2B3437] font-extrabold tracking-[1.6px] py-[18px] px-6 rounded-full outline-none cursor-pointer hover:bg-gray-100 hover:-translate-y-1 hover:shadow-xl active:scale-95 focus:ring-4 focus:ring-white/50 duration-300 transition-all"
      >
        SEND INQUIRY
      </button>
    </div>
  </div>
</section>