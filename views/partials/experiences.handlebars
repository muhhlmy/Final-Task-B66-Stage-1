<section id="experiencesSection" class="bg-white py-16 md:py-32 px-6 md:px-0">
  <div class="container mx-auto grid grid-cols-1 lg:grid-cols-3 gap-12 lg:gap-0">
    {{! Section Title }}
    <h1 class="font-extrabold text-4xl md:text-5xl tracking-[-2.4px] text-center lg:text-left">
      Experiences
      <br class="hidden lg:block" />
      Timeline
    </h1>
    {{! Experiences Container}}
    <div class="col-span-1 lg:col-span-2 grid grid-cols-1 gap-12 md:gap-24">
      {{! Experiences }}
      {{#each experiences}}
        <div class="flex flex-col">
          <span
            class="font-bold text-sm text-[#737C7F] uppercase tracking-widest mb-4"
          >
            {{start}} — {{end}}
          </span>
          <h3 class="font-extrabold text-3xl text-[#2B3437]">
            {{role}}
          </h3>
          <span class="font-semibold text-lg text-[#575E70] mt-2">
            {{company}}
          </span>
          <p class="text-base text-[#586064] mt-4">
            {{description}}
          </p>
        </div>
      {{/each}}
    </div>
  </div>
</section>