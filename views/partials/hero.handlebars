<section id="heroSection" class="bg-[#F8F9FA] py-20">
  <div class="container mx-auto grid grid-cols-2">
    {{! Text }}
    <div class="flex flex-col gap-8 justify-center">
      <h1
        class="font-extrabold text-7xl tracking-[-3.6px] text-[#2B3437] leading-20"
      >
        Hi there!,
        <br />
        I'm Muhammad Helmy.
      </h1>
      <p class="text-xl text-[#586064] leading-8">
        I am a junior full-stack developer dedicated to crafting intentional
        digital experiences. I believe in software that feels like an
        architectural masterpiece, restrained, powerful, and permanent.
      </p>
      {{! Buttons }}
      <div class="font-bold flex gap-4">
        <a
          href="#"
          class="bg-[#2B3437] text-[#F7F7FF] px-10 py-4 rounded-full flex items-center justify-center hover:-translate-y-2 hover:shadow-md duration-300 transition-all"
        >
          View Projects
        </a>
        <a
          href="#"
          class="text-[#2B3437] border border-[#ABB3B7]/30 px-10 py-4 rounded-full flex items-center justify-center gap-2 hover:-translate-y-2 hover:bg-white hover:shadow-md duration-300 transition-all"
        >
          Download CV
          <i class="fa-regular fa-circle-down"></i>
        </a>
      </div>
    </div>
    {{! Photo }}
    <div class="flex justify-end">
      <div class="relative group">
        <div
          class="absolute inset-0 border-2 border-[#2B3437] rounded-3xl transform transition-transform duration-500 group-hover:translate-x-4 group-hover:translate-y-4"
        ></div>
        <img
          src="images/photo.png"
          alt="Professional Developer"
          class="relative w-[580px] h-[680px] object-cover rounded-3xl shadow-2xl transition-transform duration-500 group-hover:-translate-y-2 group-hover:-translate-x-2 grayscale hover:grayscale-0"
        />
      </div>
    </div>
  </div>
</section>