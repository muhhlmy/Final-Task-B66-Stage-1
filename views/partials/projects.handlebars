<section id="projectsSection" class="bg-[#F8F9FA] py-16 md:py-20 px-6 md:px-0">
  <div class="container mx-auto flex flex-col gap-6 w-full">
    <h2
      class="font-extrabold text-4xl md:text-5xl tracking-[-2.4px] mb-6 md:mb-10 text-center md:text-left"
    >
      Projects
    </h2>
    {{! Projects Container }}
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 md:gap-14">
      {{! Project Card }}
      {{#each projects}}
        <div
          class="bg-white p-4 md:p-5 border border-gray-100 rounded-4xl group cursor-pointer hover:-translate-y-2 hover:shadow-[0_15px_30px_-10px_rgba(0,0,0,0.08)] active:scale-95 duration-500 transition-all flex flex-col h-full"
        >
          {{! Photo }}
          <div class="relative overflow-hidden rounded-2xl bg-gray-50">
            {{#if projectImage}}
              <img
                src="{{projectImage}}"
                alt="{{projectName}}"
                class="w-full aspect-4/3 md:aspect-16/11 object-cover transition-transform duration-700 ease-out group-hover:scale-105"
              />
            {{else}}
              <img
                src="https://placehold.co/600x450?text={{projectName}}"
                alt="{{projectName}}"
                class="w-full aspect-4/3 md:aspect-16/11 object-cover transition-transform duration-700 ease-out group-hover:scale-105"
              />
            {{/if}}

            {{! Overlay (Subtle Gradient) }}
            <div
              class="absolute inset-0 bg-linear-to-t from-black/40 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"
            ></div>
          </div>

          {{! Title & Desc }}
          <div class="mt-6 px-2 grow flex flex-col">
            <h3
              class="text-xl md:text-2xl font-bold tracking-tight text-[#171717] group-hover:text-black transition-colors duration-300"
            >
              {{projectName}}
            </h3>
            <p
              class="mt-3 text-sm md:text-base text-[#737373] leading-relaxed line-clamp-3"
            >
              {{projectDesc}}
            </p>

            {{! Tech Stack Tags }}
            {{#if tags}}
              <div class="mt-4 flex flex-wrap gap-2">
                {{#each tags}}
                  <span
                    class="px-3 py-1 bg-gray-100/80 text-[#171717] text-xs font-semibold rounded-full border border-gray-200 backdrop-blur-sm transition-colors group-hover:bg-gray-200/80"
                  >
                    {{this}}
                  </span>
                {{/each}}
              </div>
            {{/if}}

            {{! Github }}
            <div
              class="mt-auto pt-6 flex items-center justify-between opacity-0 translate-y-4 group-hover:opacity-100 group-hover:translate-y-0 transition-all duration-500 ease-out"
            >
              <a
                target="_blank"
                href="https://github.com/muhhlmy"
                class="text-sm font-bold text-[#171717] tracking-widest uppercase"
              >
                View on GitHub
              </a>
              <span
                class="bg-[#171717] text-white w-9 h-9 rounded-full flex items-center justify-center transform -rotate-45 group-hover:rotate-0 transition-transform duration-500"
              >
                <i class="fa-solid fa-arrow-right text-sm"></i>
              </span>
            </div>
          </div>
        </div>
      {{/each}}
    </div>
  </div>
</section>